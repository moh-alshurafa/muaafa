{
  "name": "معافى Design System",
  "version": "1.0.0",

  "colors": {
    "brand": {
      "primary": "#0f4c5c",
      "primaryHover": "#0d3f4e",
      "primaryDark": "#0a3642",
      "accent": "#9dce5b",
      "accentHover": "#8aba4f"
    },
    "neutral": {
      "white": "#ffffff",
      "50": "#f8fafc",
      "100": "#f1f5f9",
      "200": "#e2e8f0",
      "300": "#cbd5e1",
      "400": "#94a3b8",
      "500": "#64748b",
      "600": "#475569",
      "800": "#1e293b",
      "900": "#0f172a",
      "950": "#020617"
    },
    "semantic": {
      "success": "#9dce5b",
      "warning": "#f59e0b",
      "error": "#ef4444",
      "info": "#0f4c5c"
    }
  },

  "typography": {
    "fontFamily": {
      "base": "system-ui, -apple-system, sans-serif"
    },
    "fontWeight": {
      "medium": "500",
      "semibold": "600",
      "bold": "700",
      "black": "900"
    },
    "fontSize": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem",
      "5xl": "3rem",
      "6xl": "3.75rem",
      "7xl": "4.5rem"
    },
    "lineHeight": {
      "tight": "1.25",
      "snug": "1.375",
      "relaxed": "1.625",
      "loose": "2"
    },
    "scale": {
      "sectionHeading": "text-3xl sm:text-4xl font-black text-slate-900",
      "heroHeading": "text-4xl sm:text-5xl lg:text-6xl font-black text-slate-900",
      "cardTitle": "text-lg font-bold text-slate-900",
      "body": "text-base text-slate-500 leading-relaxed",
      "bodySmall": "text-sm text-slate-500 leading-relaxed",
      "label": "text-xs font-semibold text-slate-400 uppercase tracking-wide",
      "accentText": "text-[#0f4c5c]"
    }
  },

  "spacing": {
    "sectionPaddingY": "py-20 md:py-24",
    "containerPaddingX": "px-6 lg:px-12",
    "containerMaxWidth": "max-w-7xl mx-auto",
    "containerNarrow": "max-w-3xl mx-auto",
    "sectionGap": "mb-10 md:mb-12",
    "cardPadding": "p-6 md:p-8",
    "cardGap": "gap-6"
  },

  "borderRadius": {
    "sm": "rounded-xl",
    "md": "rounded-2xl",
    "lg": "rounded-3xl",
    "full": "rounded-full"
  },

  "shadows": {
    "card": "shadow-sm",
    "cardHover": "shadow-md",
    "modal": "shadow-xl",
    "float": "shadow-lg"
  },

  "borders": {
    "default": "border border-slate-200",
    "subtle": "border border-slate-100",
    "strong": "border-2 border-slate-200"
  },

  "backgrounds": {
    "page": "#ffffff",
    "subtle": "#f8fafc",
    "footer": "#020617"
  },

  "components": {
    "button": {
      "primary": {
        "base": "bg-[#0f4c5c] hover:bg-[#0d3f4e] text-white font-semibold rounded-xl transition-colors duration-200",
        "sizes": {
          "sm": "px-5 py-2.5 text-sm",
          "md": "px-6 py-3 text-sm",
          "lg": "px-7 py-3.5 text-base",
          "xl": "px-8 py-4 text-base"
        }
      },
      "accent": {
        "base": "bg-[#9dce5b] hover:bg-[#8aba4f] text-slate-900 font-bold rounded-xl transition-colors duration-200"
      },
      "outline": {
        "base": "border border-slate-200 hover:border-slate-300 text-slate-600 hover:text-slate-900 font-medium rounded-xl transition-colors duration-200"
      },
      "ghost": {
        "base": "bg-white/10 hover:bg-white/20 text-white font-semibold rounded-2xl transition-colors duration-200"
      }
    },
    "card": {
      "default": "bg-white rounded-2xl border border-slate-100",
      "elevated": "bg-white rounded-3xl border border-slate-200 shadow-sm",
      "subtle": "bg-slate-50 rounded-2xl",
      "dark": "bg-[#0f4c5c] rounded-3xl"
    },
    "badge": {
      "brand": "inline-flex items-center gap-2 bg-[#0f4c5c]/8 text-[#0f4c5c] text-xs font-semibold px-4 py-1.5 rounded-full",
      "dark": "bg-[#0f4c5c] text-white text-xs font-semibold px-4 py-1.5 rounded-xl",
      "light": "bg-white/10 text-white/80 text-xs font-semibold px-3 py-1 rounded-full"
    },
    "divider": {
      "horizontal": "border-t border-slate-100",
      "vertical": "border-l border-slate-200"
    }
  },

  "layout": {
    "direction": "rtl",
    "sectionPattern": [
      { "section": "Hero", "bg": "white" },
      { "section": "WeightCalculator", "bg": "slate-50" },
      { "section": "HowItWorksTimeline", "bg": "white" },
      { "section": "Features", "bg": "slate-50" },
      { "section": "Testimonials", "bg": "white" },
      { "section": "FAQ", "bg": "slate-50" },
      { "section": "FinalCTA", "bg": "white" },
      { "section": "Footer", "bg": "slate-950" }
    ],
    "grid": {
      "2col": "grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16",
      "3col": "grid grid-cols-1 md:grid-cols-3 gap-6",
      "4col": "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6"
    }
  },

  "animation": {
    "fadeUp": {
      "initial": { "opacity": 0, "y": 20 },
      "animate": { "opacity": 1, "y": 0 },
      "transition": { "duration": 0.55, "ease": [0.25, 0.1, 0.25, 1] }
    },
    "fadeIn": {
      "initial": { "opacity": 0 },
      "animate": { "opacity": 1 },
      "transition": { "duration": 0.4 }
    },
    "scaleIn": {
      "initial": { "opacity": 0, "scale": 0.95 },
      "animate": { "opacity": 1, "scale": 1 },
      "transition": { "duration": 0.4, "ease": [0.25, 0.1, 0.25, 1] }
    },
    "stagger": { "delayBetweenItems": 0.08 },
    "transition": {
      "fast": "duration-150",
      "default": "duration-200",
      "slow": "duration-300"
    }
  },

  "magicUI": {
    "borderBeam": {
      "colorFrom": "#9dce5b",
      "colorTo": "#0f4c5c",
      "duration": 8,
      "borderWidth": 1.5
    },
    "particles": {
      "color": "#9dce5b",
      "quantity": 60,
      "staticity": 40,
      "size": 0.5
    }
  }
}
